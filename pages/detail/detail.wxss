.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.date {
  font-size: 24rpx;
  color: #666;
}

.news-detail {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.cover {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
}

.news-content {
  padding: 20rpx;
}

.news-list {
  margin-bottom: 30rpx;
}

.news-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.news-index {
  width: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-right: 15rpx;
}

.news-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.tip-section {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.tip-label {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 10rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  font-style: italic;
  line-height: 1.5;
}

.info-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.info-item {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #666;
}

.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #ff6b6b;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}