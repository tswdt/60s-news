<view class="container">
  <view class="header">
    <text class="title">新闻详情</text>
    <text class="date" wx:if="{{newsData}}">{{newsData.date}}</text>
  </view>
  
  <view class="news-detail" wx:if="{{newsData}}">
    <image class="cover" src="{{newsData.cover}}" mode="aspectFill" />
    
    <view class="news-content">
      <view class="news-list">
        <view class="news-item" wx:for="{{newsData.news}}" wx:key="index">
          <text class="news-index">{{index + 1}}</text>
          <text class="news-text">{{item}}</text>
        </view>
      </view>
      
      <view class="tip-section">
        <text class="tip-label">每日金句</text>
        <text class="tip-text">{{newsData.tip}}</text>
      </view>
      
      <view class="info-section">
        <text class="info-item">创建时间: {{newsData.created}}</text>
        <text class="info-item">更新时间: {{newsData.updated}}</text>
      </view>
    </view>
  </view>
  
  <view class="loading" wx:elif="{{loading}}">
    <text>加载中...</text>
  </view>
  
  <view class="error" wx:else>
    <text>加载失败，请重试</text>
    <button class="retry-btn" bindtap="handleRetry">重新加载</button>
  </view>
</view>