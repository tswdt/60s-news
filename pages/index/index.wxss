.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 新闻图片 + 播放器包装器 */
.cover-player-wrapper {
  position: relative;
  width: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

/* 新闻图片 */
.news-image {
  width: 100%;
  display: block;
}

/* 透明悬浮播放器 */
.player-overlay {
  position: absolute;
  top: 310rpx;
  left: 0;
  width: 100%;
  padding: 30rpx;
  z-index: 2;
  box-sizing: border-box;
}

/* 播放控制区 */
.player-control {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.control-left {
  display: flex;
  align-items: center;
}

.play-btn-large {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.3);
}

.play-btn-large:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 1);
}

.play-icon-large {
  font-size: 36rpx;
  color: #333;
  margin-left: 6rpx;
}

.control-right {
  text-align: right;
}

.duration-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 进度条 */
.progress-wrapper {
  margin: 15rpx 0;
}

.progress-slider {
  width: 100%;
  margin: 0;
}

/* 波形动画 */
.waveform {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  margin-top: 15rpx;
  gap: 6rpx;
}

.bar {
  width: 4rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 2rpx;
  animation: none;
}

.bar.active {
  animation: wave 0.8s ease-in-out infinite;
}

.bar:nth-child(1) { height: 15rpx; animation-delay: 0s; }
.bar:nth-child(2) { height: 25rpx; animation-delay: 0.1s; }
.bar:nth-child(3) { height: 35rpx; animation-delay: 0.2s; }
.bar:nth-child(4) { height: 25rpx; animation-delay: 0.3s; }
.bar:nth-child(5) { height: 15rpx; animation-delay: 0.4s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
  50% { transform: scaleY(1); opacity: 1; }
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #666;
}

.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #ff6b6b;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.footer {
  text-align: center;
  padding: 20rpx;
  font-size: 20rpx;
  color: #999;
  margin-top: 20rpx;
}
