.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.date {
  font-size: 24rpx;
  color: #666;
}

.news-card {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}

.news-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.1);
}

.cover {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
}

.news-content {
  padding: 20rpx;
}

.news-list {
  margin-bottom: 20rpx;
}

.news-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: flex-start;
}

.news-index {
  width: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-right: 15rpx;
}

.news-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.5;
  color: #333;
}

.tip {
  padding: 15rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #666;
}

.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #ff6b6b;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.footer {
  text-align: center;
  padding: 20rpx;
  font-size: 20rpx;
  color: #999;
  margin-top: 20rpx;
}