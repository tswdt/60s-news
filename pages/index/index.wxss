.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 播放器区域 */
.player-section {
  width: 100%;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.player-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1;
}

/* 播放器头部 */
.player-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 2;
}

.header-left {
  display: flex;
  flex-direction: column;
  position: relative;
}

.yellow-line {
  display: none;
}

.title-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 0;
  line-height: 1.1;
  text-align: right;
}

.subtitle-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 0;
  margin-top: 15rpx;
  text-align: right;
}

.header-right {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.date-box {
  padding: 15rpx 35rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date-day {
  font-size: 120rpx;
  font-weight: bold;
  color: #000;
  line-height: 1;
}

.date-month {
  font-size: 50rpx;
  font-weight: bold;
  color: #000;
  line-height: 1;
  margin-top: -20rpx;
}

/* 新闻区域 */
.news-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 新闻条目 */
.news-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.news-item:last-child {
  margin-bottom: 0;
}

/* 新闻序号 */
.news-index {
  color: #ff6b6b;
  font-size: 32rpx;
  font-weight: bold;
  min-width: 50rpx;
  flex-shrink: 0;
}

/* 新闻内容 */
.news-content {
  color: #333;
  font-size: 32rpx;
  line-height: 1.6;
  flex: 1;
}

/* 播放控制区 */
.player-control {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 2;
}

.control-left {
  display: flex;
  align-items: center;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.play-icon {
  width: 0;
  height: 0;
  border-top: 24rpx solid transparent;
  border-bottom: 24rpx solid transparent;
  border-left: 40rpx solid #fff;
  margin-left: 8rpx;
}

.pause-icon {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pause-bar {
  width: 12rpx;
  height: 48rpx;
  background-color: #fff;
  border-radius: 4rpx;
}

.control-right {
  text-align: right;
}

.duration-text {
  font-size: 22rpx;
  color: #666;
}

/* 进度条 */
.progress-wrapper {
  display: flex;
  align-items: center;
  margin: 10rpx 0;
  position: relative;
  z-index: 2;
  gap: 20rpx;
}

.time-text {
  font-size: 24rpx;
  color: #fff;
  min-width: 70rpx;
  text-align: center;
  font-family: monospace;
}

.progress-slider {
  flex: 1;
  margin: 0;
}

.progress-slider::before,
.progress-slider::after {
  display: none;
}

/* 波形动画 */
.waveform {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  margin-top: 10rpx;
  gap: 6rpx;
  position: relative;
  z-index: 2;
}

.bar {
  width: 4rpx;
  background: #fff;
  border-radius: 2rpx;
  animation: none;
}

.bar.active {
  animation: wave 0.8s ease-in-out infinite;
}

.bar:nth-child(1) { height: 15rpx; animation-delay: 0s; }
.bar:nth-child(2) { height: 25rpx; animation-delay: 0.1s; }
.bar:nth-child(3) { height: 35rpx; animation-delay: 0.2s; }
.bar:nth-child(4) { height: 25rpx; animation-delay: 0.3s; }
.bar:nth-child(5) { height: 15rpx; animation-delay: 0.4s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
  50% { transform: scaleY(1); opacity: 1; }
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #666;
}

.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #ff6b6b;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.footer {
  text-align: center;
  padding: 20rpx;
  font-size: 20rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 广告横幅 */
.ad-section {
  margin-top: 20rpx;
  position: relative;
  z-index: 10;
}
