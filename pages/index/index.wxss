.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.date {
  font-size: 24rpx;
  color: #666;
}

/* 音频播放器包装器 */
.audio-player-wrapper {
  position: relative;
  width: 100%;
  height: 500rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

/* 背景封面图 */
.player-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 渐变遮罩 */
.gradient-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
  z-index: 2;
}

/* 悬浮播放器控件 */
.player-float {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx;
  z-index: 3;
  box-sizing: border-box;
}

/* 日期时间显示 */
.datetime-bar {
  margin-bottom: 20rpx;
}

.datetime-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 播放控制区 */
.player-control {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.control-left {
  display: flex;
  align-items: center;
}

.play-btn-large {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.3);
}

.play-btn-large:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 1);
}

.play-icon-large {
  font-size: 36rpx;
  color: #333;
  margin-left: 6rpx;
}

.track-info {
  margin-left: 20rpx;
}

.track-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.track-artist {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.control-right {
  text-align: right;
}

.duration-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 进度条 */
.progress-wrapper {
  margin: 15rpx 0;
}

.progress-slider {
  width: 100%;
  margin: 0;
}

/* 波形动画 */
.waveform {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  margin-top: 15rpx;
  gap: 6rpx;
}

.bar {
  width: 4rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 2rpx;
  animation: none;
}

.bar.active {
  animation: wave 0.8s ease-in-out infinite;
}

.bar:nth-child(1) { height: 15rpx; animation-delay: 0s; }
.bar:nth-child(2) { height: 25rpx; animation-delay: 0.1s; }
.bar:nth-child(3) { height: 35rpx; animation-delay: 0.2s; }
.bar:nth-child(4) { height: 25rpx; animation-delay: 0.3s; }
.bar:nth-child(5) { height: 15rpx; animation-delay: 0.4s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
  50% { transform: scaleY(1); opacity: 1; }
}

/* 新闻列表卡片 */
.news-list-card {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}

.news-list-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.1);
}

.news-content {
  padding: 10rpx;
}

.news-list {
  margin-bottom: 20rpx;
}

.news-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: flex-start;
}

.news-index {
  width: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-right: 15rpx;
}

.news-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.5;
  color: #333;
}

.tip {
  padding: 15rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #666;
}

.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #ff6b6b;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.footer {
  text-align: center;
  padding: 20rpx;
  font-size: 20rpx;
  color: #999;
  margin-top: 20rpx;
}