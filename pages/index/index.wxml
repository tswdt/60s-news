<view class="container">
  <!-- 音频播放器 -->
  <view class="player-section" wx:if="{{newsData}}" style="background-image: url('{{backgroundImage}}'); background-size: cover; background-position: center;">
    <!-- 顶部区域 - 早闻天下 -->
    <view class="player-header">
      <view class="header-left">
        <view class="yellow-line"></view>
        <view class="title-text">早闻天下</view>
        <view class="subtitle-text">每天读报一分钟，知晓天下事</view>
      </view>
    </view>

    <!-- 播放控制区 -->
    <view class="player-control">
      <view class="control-left">
        <view class="play-btn" bindtap="playAudio">
          <view wx:if="{{!isPlaying}}" class="play-icon"></view>
          <view wx:else class="pause-icon">
            <view class="pause-bar"></view>
            <view class="pause-bar"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 进度条 -->
    <view class="progress-wrapper">
      <text class="time-text">{{formatTime(currentTime)}}</text>
      <slider class="progress-slider" min="0" max="{{audioDuration}}" value="{{currentTime}}" block-size="16" activeColor="#fff" backgroundColor="rgba(255,255,255,0.3)" bindchange="seekAudio" bindchanging="seekAudio"/>
      <text class="time-text">{{formatTime(audioDuration)}}</text>
    </view>

    <!-- 音频波形动画 -->
    <view class="waveform" wx:if="{{isPlaying}}">
      <view class="bar {{isPlaying ? 'active' : ''}}"></view>
      <view class="bar {{isPlaying ? 'active' : ''}}"></view>
      <view class="bar {{isPlaying ? 'active' : ''}}"></view>
      <view class="bar {{isPlaying ? 'active' : ''}}"></view>
      <view class="bar {{isPlaying ? 'active' : ''}}"></view>
    </view>
  </view>

  <!-- 新闻文字列表 -->
  <view class="news-section" wx:if="{{newsData && newsData.news.length > 0}}">
    <view class="news-item" wx:for="{{newsData.news}}" wx:key="index">
      <text class="news-index">{{index + 1}}</text>
      <text class="news-content">{{item}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:elif="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 加载失败 -->
  <view class="error" wx:else>
    <text>加载失败，请重试</text>
    <button class="retry-btn" bindtap="handleRetry">重新加载</button>
  </view>

  <view class="footer">
    <text class="footer-text">数据来源: 60s-static.viki.moe</text>
  </view>
</view>
